# Salin file ini menjadi `.env` lalu isi nilainya. JANGAN commit file `.env`.

# ---- Supabase (WAJIB) ----
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-supabase-service-or-anon-key

# ---- Server ----
PORT=3000
# WAJIB. String acak panjang (rahasia sesi login). Server menolak start
# bila kosong (lihat src/config/env.js).
SESSION_SECRET=ganti-dengan-string-acak-panjang

# ---- Deepgram (speech-to-text) ----
DEEPGRAM_KEY=your-deepgram-api-key

# ---- MQTT broker (opsional) ----
# Bila dikosongkan, dipakai nilai default lama (HiveMQ Cloud proyek ini).
# Sebaiknya diisi & JANGAN hardcode kredensial di kode.
MQTT_HOST=xxxxxxxxxxxx.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_PROTOCOL=mqtts
MQTT_USERNAME=your-mqtt-username
MQTT_PASSWORD=your-mqtt-password
