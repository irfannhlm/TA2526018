    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      const CURRENT_CLASS = '<%= currentClass || "" %>';
      const CURRENT_USERNAME = '<%= username %>';

      function openAddModal() {
          document.getElementById('rfidInputAdd').value = '';
          document.getElementById('addModalTitle').innerText = 'Tambah Mahasiswa Baru';
          new bootstrap.Modal(document.getElementById('addModal')).show();
      }

      function registerUnknown(uid) {
          document.getElementById('rfidInputAdd').value = uid;
          document.getElementById('addModalTitle').innerText = 'Registrasi Kartu Baru';
          // Tutup listModal jika terbuka
          const listModalEl = document.getElementById('listModal');
          const listModal = bootstrap.Modal.getInstance(listModalEl);
          if(listModal) listModal.hide();
          new bootstrap.Modal(document.getElementById('addModal')).show();
      }

      function openEditModal(id, name, nim, rfid) {
        const listModalEl = document.getElementById('listModal');
        const listModal = bootstrap.Modal.getInstance(listModalEl);
        if(listModal) listModal.hide();

        document.getElementById("editId").value = id;
        document.getElementById("editName").value = name;
        document.getElementById("editNim").value = nim;
        document.getElementById("editRfid").value = rfid;
        setTimeout(() => {
            new bootstrap.Modal(document.getElementById("editModal")).show();
        }, 300);
      }

      function openEditClassModal(id, name, code, lecturer, lecturerUserId) {
          document.getElementById("editClassId").value = id;
          document.getElementById("editClassName").value = name;
          document.getElementById("editClassCode").value = code;
          document.getElementById("editClassLecturer").value = lecturer || '';
          const sel = document.getElementById("editClassLecturerUserId");
          if (sel) sel.value = lecturerUserId || '';
          new bootstrap.Modal(document.getElementById("editClassModal")).show();
      }

      // Konfirmasi hapus mahasiswa via SweetAlert
      function confirmDeleteStudent(id, name) {
          // Tutup modal list dulu
          const listModalEl = document.getElementById('listModal');
          const listModal = bootstrap.Modal.getInstance(listModalEl);
          if(listModal) listModal.hide();

          setTimeout(() => {
              Swal.fire({
                  title: 'Hapus Mahasiswa?',
                  html: `Mahasiswa <strong>${name}</strong> akan dihapus dari database.<br><small class="text-muted">Aksi ini tidak bisa dibatalkan.</small>`,
                  icon: 'warning',
                  showCancelButton: true,
                  confirmButtonColor: '#d81b60',
                  cancelButtonColor: '#888888',
                  confirmButtonText: 'Ya, Hapus!',
                  cancelButtonText: 'Batal',
                  borderRadius: '20px'
              }).then((result) => {
                  if (result.isConfirmed) {
                      document.getElementById('deleteStudentId').value = id;
                      document.getElementById('deleteStudentForm').submit();
                  }
              });
          }, 300);
      }

      // Konfirmasi hapus kelas via SweetAlert
      function confirmDeleteClass(id, name) {
          Swal.fire({
              title: 'Hapus Kelas?',
              html: `Kelas <strong>${name}</strong> beserta seluruh mahasiswanya akan dihapus permanen.<br><small class="text-muted">Aksi ini tidak bisa dibatalkan.</small>`,
              icon: 'warning',
              showCancelButton: true,
              confirmButtonColor: '#d81b60',
              cancelButtonColor: '#888888',
              confirmButtonText: 'Ya, Hapus Kelas!',
              cancelButtonText: 'Batal',
          }).then((result) => {
              if (result.isConfirmed) {
                  document.getElementById('deleteClassId').value = id;
                  document.getElementById('deleteClassForm').submit();
              }
          });
      }

      // Konfirmasi reset semua data (ganti semester)
      function confirmResetAll() {
          Swal.fire({
              title: 'Ganti Semester?',
              html: `<strong>Semua data kelas dan mahasiswa akan dihapus!</strong><br><br>Pastikan Anda sudah menyimpan data yang diperlukan sebelum melanjutkan.<br><br><small class="text-danger">⚠️ Aksi ini TIDAK BISA dibatalkan.</small>`,
              icon: 'warning',
              showCancelButton: true,
              confirmButtonColor: '#d32f2f',
              cancelButtonColor: '#888888',
              confirmButtonText: 'Ya, Hapus Semua!',
              cancelButtonText: 'Batal',
              input: 'text',
              inputPlaceholder: 'Ketik "HAPUS" untuk konfirmasi',
              inputAttributes: { autocomplete: 'off' },
              preConfirm: (value) => {
                  if (value !== 'HAPUS') {
                      Swal.showValidationMessage('Ketik "HAPUS" (huruf kapital) untuk konfirmasi');
                  }
              }
          }).then((result) => {
              if (result.isConfirmed) {
                  document.getElementById('resetAllForm').submit();
              }
          });
      }

      // Konfirmasi hapus user
      function confirmDeleteUser(event, form) {
          event.preventDefault();
          Swal.fire({
              title: 'Hapus Akun?',
              text: 'Akun ini akan dihapus dari sistem.',
              icon: 'warning',
              showCancelButton: true,
              confirmButtonColor: '#d81b60',
              cancelButtonColor: '#888888',
              confirmButtonText: 'Ya, Hapus!',
              cancelButtonText: 'Batal',
          }).then((result) => {
              if (result.isConfirmed) {
                  form.submit();
              }
          });
          return false;
      }
    </script>

    <script>
        // 1. SISTEM MENGINGAT TAB
        document.addEventListener("DOMContentLoaded", function () {
            let activePillId = localStorage.getItem("activePill");
            if (activePillId) {
                let triggerEl = document.querySelector(`button[data-bs-target="${activePillId}"]`);
                if (triggerEl) {
                    let pillInstance = new bootstrap.Tab(triggerEl);
                    pillInstance.show();
                }
            }
            let pillElements = document.querySelectorAll('button[data-bs-toggle="pill"]');
            pillElements.forEach(function (pill) {
                pill.addEventListener("shown.bs.tab", function (event) {
                    let targetId = event.target.getAttribute("data-bs-target");
                    localStorage.setItem("activePill", targetId);
                });
            });
        });

        // 2. SISTEM AUTO-REFRESH
        let isServerOffline = false;

        async function updateData() {
            try {
                const response = await fetch(`/api/realtime-data?kelas=${encodeURIComponent(CURRENT_CLASS)}`, { cache: 'no-store' });
                if (!response.ok) throw new Error("Gagal ambil data API");

                const data = await response.json();
                
                // Update Tabel Antrean
                const listBody = document.querySelector('#tabel-antrean-body');
                if (listBody && data.scannedList) {
                    if(data.scannedList.length === 0) {
                        listBody.innerHTML = '<tr><td class="text-center text-muted py-5">Belum ada aktivitas scan.</td></tr>';
                    } else {
                        let newHtml = '';
                        data.scannedList.forEach(item => {
                            let rowClass = !item.isRegistered ? 'pulse-red' : '';
                            
                            let userInfoHtml = item.isRegistered
                                ? `<div class="fw-bold text-dark">${item.name}</div><small class="text-muted">${item.nim}</small>`
                                : `<span class="badge bg-danger rounded-pill px-3 py-2 mb-1">UNKNOWN</span><div style="font-size: 10px;" class="text-danger">Belum Terdaftar</div>`;

                            let registerBtn = !item.isRegistered
                                ? `<button onclick="registerUnknown('${item.uid}')" class="btn btn-sm btn-primary rounded-pill px-3 fw-bold me-1" style="background: var(--dark-pink); border: none;"><i class="fas fa-user-plus me-1"></i> Daftarkan</button>`
                                : '';

                            let deleteBtn = `<form action="/admin/manage-uid" method="POST" class="d-inline">
                                <input type="hidden" name="current_class" value="${CURRENT_CLASS}">
                                <input type="hidden" name="username" value="${CURRENT_USERNAME}">
                                <input type="hidden" name="action" value="delete">
                                <input type="hidden" name="uid" value="${item.uid}">
                                <input type="hidden" name="entry_id" value="${item.id}">
                                <button type="submit" class="btn btn-sm btn-light text-secondary rounded-circle" title="Hapus dari sesi"><i class="fas fa-times"></i></button>
                            </form>`;

                            newHtml += `
                                <tr class="${rowClass}">
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="bg-light rounded-circle p-2 text-secondary"><i class="fas fa-id-card"></i></div>
                                            <div><div class="fw-bold small text-secondary">RFID UID</div><div class="font-monospace text-dark fw-bold">${item.uid}</div></div>
                                        </div>
                                    </td>
                                    <td>${userInfoHtml}</td>
                                    <td class="text-end pe-3">${registerBtn}${deleteBtn}</td>
                                </tr>
                            `;
                        });
                        listBody.innerHTML = newHtml;
                    }
                }
                
                // Update Perangkat
                if (data.devices && data.devices.length > 0) {
                    const urlParams = new URLSearchParams(window.location.search);
                    const currentDeviceId = urlParams.get('device') || String(data.devices[0].id);
                    const dev = data.devices.find(d => String(d.id) === String(currentDeviceId)) || data.devices[0];
                    const isOnline = dev.status === 'online';
                    
                    const bgCard = document.querySelector('#device-card-bg');
                    if(bgCard) bgCard.style.backgroundColor = isOnline ? '#e8f5e9' : '#ffebee';

                    const statusContainer = document.querySelector('#device-status-container');
                    if(statusContainer) {
                        let badgeHtml = isOnline 
                            ? `<span class="badge bg-success text-white badge-custom shadow-sm"><i class="fas fa-wifi me-1"></i> ONLINE</span>` 
                            : `<span class="badge bg-danger text-white badge-custom shadow-sm"><i class="fas fa-wifi-slash me-1"></i> OFFLINE</span>`;
                        statusContainer.innerHTML = `${badgeHtml} <small class="text-muted font-monospace">${dev.id}</small>`;
                    }

                    const batContainer = document.querySelector('#device-battery-container');
                    const batText = document.querySelector('#device-battery-text');
                    const batLabel = document.querySelector('#device-battery-label');
                    
                    if (batContainer && batText && batLabel) {
                        let batVal = dev.battery;
                        let hasBat = (batVal !== null && batVal !== undefined && batVal !== '');
                        batText.innerText = hasBat ? `${batVal}%` : '--';
                        batLabel.innerText = hasBat ? 'Status Daya Perangkat' : 'Belum ada data dari broker';
                        batContainer.style.color = isOnline ? ((hasBat && batVal > 20) ? 'var(--dark-pink)' : '#dc3545') : '#999';
                    }
                }
            } catch (err) {
                console.log("Menunggu koneksi data realtime...");
            }
        }

        setInterval(updateData, 2000);
    </script>

</body>
</html>