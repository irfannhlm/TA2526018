<!DOCTYPE html>
<html lang="id">
  <head>
    <title><%= title || "Terjadi Kesalahan" %></title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg-color: #ffe6f2;
        --primary-pink: #ff80ab;
        --dark-pink: #d81b60;
        --text-dark: #4a4a4a;
        --shadow-soft: 0 10px 30px rgba(255, 105, 180, 0.2);
      }
      body {
        background-color: var(--bg-color);
        font-family: "Poppins", sans-serif;
        color: var(--text-dark);
        min-height: 100vh;
      }
      .card-error {
        border: none;
        border-radius: 25px;
        box-shadow: var(--shadow-soft);
        background: rgba(255, 255, 255, 0.95);
        padding: 40px;
        width: 460px;
        max-width: 92vw;
        text-align: center;
      }
      .error-icon {
        font-size: 3rem;
        color: var(--dark-pink);
        margin-bottom: 12px;
      }
      .btn-rose {
        background: linear-gradient(135deg, #ff80ab, #d81b60);
        color: white;
        border: none;
        padding: 10px 28px;
        font-weight: 600;
        border-radius: 50px;
        transition: all 0.3s ease;
        box-shadow: 0 5px 15px rgba(216, 27, 96, 0.3);
      }
      .btn-rose:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(216, 27, 96, 0.4);
        color: white;
      }
    </style>
  </head>
  <body class="d-flex justify-content-center align-items-center">
    <div class="card card-error">
      <div class="error-icon"><i class="fas fa-circle-exclamation"></i></div>
      <h4 class="fw-bold" style="color: var(--text-dark)">
        <%= title || "Input Tidak Valid" %>
      </h4>
      <p class="text-muted mb-4"><%= message %></p>
      <button type="button" class="btn btn-rose" onclick="history.back()">
        <i class="fas fa-arrow-left me-2"></i> Kembali
      </button>
    </div>
  </body>
</html>
