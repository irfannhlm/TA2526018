<!DOCTYPE html>
<html lang="id">
  <head>
    <title>404 — Halaman Tidak Ditemukan</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --bg-color: #ffe6f2;
        --primary-pink: #ff80ab;
        --dark-pink: #d81b60;
        --text-dark: #4a4a4a;
        --shadow-soft: 0 10px 30px rgba(255, 105, 180, 0.2);
      }

      body {
        background-color: var(--bg-color);
        font-family: "Poppins", sans-serif;
        color: var(--text-dark);
        height: 100vh;
        overflow: hidden;
        position: relative;
      }

      /* Dekorasi Background */
      .circle-decoration {
        position: absolute;
        border-radius: 50%;
        background: linear-gradient(135deg, #ff80ab, #f06292);
        opacity: 0.1;
        z-index: -1;
      }
      .circle-1 {
        width: 300px;
        height: 300px;
        top: -50px;
        right: -50px;
      }
      .circle-2 {
        width: 200px;
        height: 200px;
        bottom: 50px;
        left: -50px;
      }

      .card-404 {
        border: none;
        border-radius: 25px;
        box-shadow: var(--shadow-soft);
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        padding: 48px 40px;
        width: 440px;
        max-width: 92vw;
        text-align: center;
      }

      .code-404 {
        font-size: 5rem;
        font-weight: 700;
        line-height: 1;
        background: linear-gradient(135deg, #ff80ab, #d81b60);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .btn-rose {
        background: linear-gradient(135deg, #ff80ab, #d81b60);
        color: white;
        border: none;
        padding: 12px 28px;
        font-weight: 600;
        border-radius: 50px;
        transition: all 0.3s ease;
        box-shadow: 0 5px 15px rgba(216, 27, 96, 0.3);
      }
      .btn-rose:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(216, 27, 96, 0.4);
        color: white;
      }

      .url-badge {
        font-size: 0.8rem;
        word-break: break-all;
        background-color: #fff0f6;
        border-radius: 12px;
        padding: 8px 14px;
        display: inline-block;
        color: var(--dark-pink);
      }

      @media (max-width: 575px) {
        body {
          height: auto;
          min-height: 100vh;
          overflow-y: auto;
          padding: 24px 0;
        }
        .card-404 {
          padding: 36px 24px;
          border-radius: 20px;
        }
        .code-404 {
          font-size: 4rem;
        }
        .circle-1 {
          width: 200px;
          height: 200px;
        }
        .circle-2 {
          width: 140px;
          height: 140px;
        }
      }
    </style>
  </head>
  <body class="d-flex justify-content-center align-items-center">
    <div class="circle-decoration circle-1"></div>
    <div class="circle-decoration circle-2"></div>

    <div class="card card-404">
      <div class="code-404">404</div>
      <h4 class="fw-bold mt-2" style="color: var(--text-dark)">
        Halaman Tidak Ditemukan
      </h4>
      <p class="text-muted small mb-3">
        Maaf, halaman yang kamu cari tidak tersedia atau sudah dipindahkan.
      </p>

      <% if (typeof url !== 'undefined' && url) { %>
      <div class="mb-4">
        <span class="url-badge"
          ><i class="fas fa-link me-1"></i> <%= url %></span
        >
      </div>
      <% } %>

      <a href="/" class="btn btn-rose">
        <i class="fas fa-home me-2"></i> Kembali ke Beranda
      </a>

      <div class="text-center mt-4">
        <small class="text-muted" style="font-size: 0.75rem">© TA252601018</small>
      </div>
    </div>
  </body>
</html>
